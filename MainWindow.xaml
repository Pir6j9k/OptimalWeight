<Window x:Class="OptimalWeight.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OptimalWeight"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="auto"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="15">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="5">
                    <TextBlock Text="Рост в сантиметрах" Margin="5"/>
                    <TextBox x:Name="TxbHeight" Width="100" Margin="5"/>
                </StackPanel>
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="5">
                    <TextBlock Text="Вес в килограммах" Margin="5"/>
                    <TextBox x:Name="TxbWeight" Width="100" Margin="5"/>
                </StackPanel>
            </Grid>
        </StackPanel>

        <GroupBox Grid.Row="0" Grid.Column="1" Header="Пол" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="15">
            <StackPanel Margin="10">
                <RadioButton x:Name="RbMale" Content="Мужчина" Margin="5"/>
                <RadioButton x:Name="RbFemale" Content="Женщина" Margin="5"/>
            </StackPanel>
        </GroupBox>

        <StackPanel Grid.Row="1" Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Horizontal">
            <TextBlock Text="Результат" Margin="5"/>
            <TextBox x:Name="TxbResult" Width="100" Margin="5" TextWrapping="WrapWithOverflow" IsReadOnly="True"/>
        </StackPanel>

        <Border Grid.Column="1" Grid.Row="1" Margin="15" Padding="5" CornerRadius="10" BorderThickness="1" BorderBrush="#d5dfe5">
            <Button Content="Вычислить" Background="White" BorderThickness="0" Click="Button_Click"/>
        </Border>
        
    </Grid>
</Window>
